{
  "manifest_version": 3,
  "name": "Reading Study Extension",
  "version": "1.1",
  "description": "Reading comprehension study extension",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://www.semanticscholar.org/*",
    "https://readinginterfacestudy-production.up.railway.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.semanticscholar.org/reader/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "EI Study — Session Monitor"
  }
}
